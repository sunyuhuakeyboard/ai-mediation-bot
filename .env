# ---- 运行模式 ----
OFFLINE_MODE=0
DEBUG=0
CONVERSATION_SCENE=electronic_delivery

# ---- 存储 ----
PG_DSN=postgresql+asyncpg://mediation:mediation@postgres:5432/mediation
REDIS_URL=redis://redis:6379/0
CALL_STATE_TTL=3600

# ---- 小模型意图分类（可选；不配则用关键词分类） ----
CLASSIFIER_TIMEOUT_MS=250

# ---- LLM（OpenAI兼容：豆包方舟/Qwen/DeepSeek/vLLM） ----
LLM_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
LLM_API_KEY=274bd083-7cc5-4043-b026-b84acba21b3d
LLM_MODEL=doubao-seed-2-0-mini-260428
LLM_TEMPERATURE=0.3
LLM_MAX_TOKENS=60
LLM_FIRST_TOKEN_TIMEOUT_MS=1500
LLM_TOTAL_TIMEOUT_MS=3000
REPLY_MAX_CHARS=48

# 金额/时间复述强制模板渲染（零幻觉）
PLAN_CONFIRM_FORCE_TEMPLATE=1

# ---- OKCTI / LLM-IVR SSE 对接 ----
