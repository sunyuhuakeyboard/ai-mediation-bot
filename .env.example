# ---- 运行模式 ----
OFFLINE_MODE=0                 # 1=无PG/Redis演示模式
DEBUG=0

# ---- 存储 ----
PG_DSN=postgresql+asyncpg://mediation:mediation@localhost:5432/mediation
REDIS_URL=redis://localhost:6379/0
CALL_STATE_TTL=3600

# ---- 小模型意图分类（可选；不配则用关键词分类） ----
# CLASSIFIER_URL=http://127.0.0.1:8100/classify
CLASSIFIER_TIMEOUT_MS=250

# ---- LLM（OpenAI兼容：豆包方舟/Qwen/DeepSeek/vLLM） ----
LLM_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
LLM_API_KEY=
LLM_MODEL=doubao-pro-32k
LLM_TEMPERATURE=0.3
LLM_MAX_TOKENS=60
LLM_TOTAL_TIMEOUT_MS=1500
REPLY_MAX_CHARS=48

# 金额/时间复述强制模板渲染（零幻觉）
PLAN_CONFIRM_FORCE_TEMPLATE=1
