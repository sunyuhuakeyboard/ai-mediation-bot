# ---- 运行模式 ----
OFFLINE_MODE=0                 # 1=无PG/Redis演示模式
DEBUG=0

# ---- 存储 ----
PG_DSN=postgresql+asyncpg://mediation:mediation@localhost:5432/mediation
REDIS_URL=redis://localhost:6379/0
CALL_STATE_TTL=3600

# ---- 小模型意图分类（可选；不配则用关键词分类） ----
# CLASSIFIER_URL=http://127.0.0.1:8100/classify
CLASSIFIER_TIMEOUT_MS=250

# ---- LLM（OpenAI兼容：豆包方舟/Qwen/DeepSeek/vLLM） ----
LLM_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
LLM_API_KEY=
LLM_MODEL=doubao-seed-2-0-mini-260428
LLM_TEMPERATURE=0.3
LLM_MAX_TOKENS=60
LLM_TOTAL_TIMEOUT_MS=1500
REPLY_MAX_CHARS=48

# 金额/时间复述强制模板渲染（零幻觉）
PLAN_CONFIRM_FORCE_TEMPLATE=1

# ---- OKCTI / LLM-IVR SSE 对接 ----
# 外呼平台回调地址：
#   http://服务器IP:8000/ivr/okcti/welcome
OKCTI_AUTH_ENABLED=0
OKCTI_APP_ID=
OKCTI_APP_SECRET=
OKCTI_RESPONSE_CHARSET=UTF-8
OKCTI_FORCE_START=1
OKCTI_TRANSFER_SKILL=人工坐席
OKCTI_TTS_SPK_NAME=
OKCTI_MSG_CHUNK_CHARS=80
OKCTI_VOICE_ALLOW_STOP=1
OKCTI_VOICE_BLOCK_TIME=0
OKCTI_VOICE_TIMEOUT=0
OKCTI_VOICE_MIN_SPEAK=0
OKCTI_VOICE_MIN_PAUSE=0

# ---- OKCTI 公司 / 分机 / WebRTC SDK 配置 ----
CTI_COMPANY_ID=
CTI_EXTENSION_90001_NUMBER=
CTI_EXTENSION_90001_PASSWORD=
CTI_EXTENSION_90002_NUMBER=
CTI_EXTENSION_90002_PASSWORD=
VITE_WS_CTI_URL=
VITE_APP_WEBRTC=true
VITE_APP_WEBRTC_SIP=
VITE_APP_WEBRTC_PORT=
VITE_APP_WEBRTC_WSS=
VITE_APP_WEBRTC_DEBUG=false
VITE_APP_WEBRTC_STUN=
